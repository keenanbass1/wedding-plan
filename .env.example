# Database
DATABASE_URL="postgresql://user:password@localhost:5432/weddingplan"

# Supabase Authentication
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Claude API
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# Claude Model (haiku=cheap, sonnet=best)
CLAUDE_MODEL="claude-3-5-haiku-20241022"

# Email (Resend)
RESEND_API_KEY="re_your-key-here"
EMAIL_FROM="noreply@bower.com"
RESEND_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Upstash Redis (rate limiting - required for production, optional for dev)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# Sentry Error Monitoring (optional in dev, recommended for production)
NEXT_PUBLIC_SENTRY_DSN="https://your-dsn@o0.ingest.sentry.io/0"
SENTRY_ORG="your-org"
SENTRY_PROJECT="wedding-plan"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# Optional: Local LLM
OLLAMA_URL="http://localhost:11434"
